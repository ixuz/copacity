{
  "image": "ghcr.io/ixuz/dev-container:v1.0.2",
  "workspaceFolder": "/copacity",
  "workspaceMount": "source=${localWorkspaceFolder},target=/copacity,type=bind,consistency=cached",
  "remoteUser": "ubuntu",
  "updateRemoteUserUID": true,
  "customizations": {
    "vscode": {
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash",
        "C_Cpp.default.compilerPath": "/usr/bin/x86_64-w64-mingw32-g++",
        "C_Cpp.default.cppStandard": "c++23",
        "C_Cpp.default.intelliSenseMode": "linux-gcc-x64",
        "editor.formatOnSave": false
      },
      "extensions": [
        "ms-vscode.cpptools"
      ]
    }
  }
}